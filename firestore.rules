rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }
    
    // Check if user is referencing their own document
    function isUser(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    
    // Check if user is admin (super admin or has admin role in admins/users collection)
    function isAdmin() {
      return isAuth() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    // Users collection rules
    match /users/{uid} {
      allow read, write: if isUser(uid) || isAdmin();
    }
    
    // Clients collection rules
    match /clients/{uid} {
      allow read, write: if isUser(uid) || isAdmin();
    }
    
    // Workers collection rules
    match /workers/{uid} {
      // Anyone can read approved/active workers. Admin and owner can read any worker.
      allow read: if resource.data.status == 'approved' || resource.data.status == 'active' || isUser(uid) || isAdmin();
      // Users can register their own worker application.
      allow create: if isUser(uid);
      // Users can update their own profile, but cannot edit the "status" field unless they are an admin.
      allow update: if isUser(uid) && 
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'approvedAt', 'approvedBy', 'rejectedAt', 'rejectedBy'])) 
        || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Admins collection rules
    match /admins/{uid} {
      allow read: if isAuth();
      allow write: if isAdmin() || (isAuth() && !exists(/databases/$(database)/documents/admins/$(uid))); // Auto-create first admin
    }
    
    // Jobs collection rules
    match /jobs/{jobId} {
      // Authenticated users can view jobs.
      allow read: if isAuth();
      // Any client can post jobs.
      allow create: if isAuth() && request.resource.data.clientId == request.auth.uid;
      // Only the client owner can modify/delete their job.
      allow update: if isAuth() && (resource.data.clientId == request.auth.uid || isAdmin());
      allow delete: if isAuth() && (resource.data.clientId == request.auth.uid || isAdmin());
    }
    
    // Bids collection rules
    match /bids/{bidId} {
      // Owner of bid, client who posted the job, or admin can read bids.
      allow read: if isAuth() && (
        resource.data.workerId == request.auth.uid ||
        get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.clientId == request.auth.uid ||
        isAdmin()
      );
      // Only approved workers can submit bids.
      allow create: if isAuth() && 
        request.resource.data.workerId == request.auth.uid &&
        (get(/databases/$(database)/documents/workers/$(request.auth.uid)).data.status == 'approved' ||
         get(/databases/$(database)/documents/workers/$(request.auth.uid)).data.status == 'active');
      // Only the bidder can edit/delete their bid, or job owner can update status.
      allow update: if isAuth() && (
        resource.data.workerId == request.auth.uid ||
        get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.clientId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAuth() && (resource.data.workerId == request.auth.uid || isAdmin());
    }
    
    // Notifications collection rules
    match /notifications/{uid}/items/{itemId} {
      allow read, write: if isUser(uid) || isAdmin();
    }
    
    // Reviews collection rules
    match /reviews/{jobId} {
      allow read: if true;
      // Enforce job-completion verification and prevent duplicate reviews (reviewId is equal to jobId)
      allow create: if isAuth() &&
        request.resource.data.clientId == request.auth.uid &&
        get(/databases/$(database)/documents/jobs/$(jobId)).data.clientId == request.auth.uid &&
        get(/databases/$(database)/documents/jobs/$(jobId)).data.hiredWorkerId == request.resource.data.workerId &&
        get(/databases/$(database)/documents/jobs/$(jobId)).data.status == 'completed' &&
        jobId == request.resource.data.jobId;
      allow update, delete: if isAdmin();
    }
  }
}
